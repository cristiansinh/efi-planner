{
  "name": "dortania-hardware-checker",
  "version": "1.0.0",
  "description": "Hardware checker and EFI planner for Hackintosh following Dortania guides.",
  "license": "MIT",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "vite:dev": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron . --enable-logging",
    "dev": "concurrently -k \"npm run vite:dev\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "build": "npm run vite:build",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.475.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.2",
    "vite": "^6.0.11",
    "wait-on": "^8.0.2"
  }
}
